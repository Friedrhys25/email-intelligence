NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Phase 3+
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=
# Temporarily set true only when copying a new refresh token from the OAuth callback.
EXPOSE_REFRESH_TOKEN_ON_CALLBACK=false

# Phase 7+
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Phase 9+
DISCORD_WEBHOOK_URL=

# Phase 10+
EMAIL_FETCH_LIMIT=10
DIGEST_CRON=0 10,21 * * *
SCHEDULER_TIMEZONE=Asia/Manila
SCHEDULER_ENABLED=false

# Production deployment sets SCHEDULER_ENABLED=true in Render.
